# ── Copy this file to .env and fill in your values ──────────────────
# On Railway: add these as Environment Variables in the dashboard

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/latif_landmark?retryWrites=true&w=majority

# JWT Secret — use a long random string
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars

JWT_EXPIRES_IN=7d

# Admin seed credentials
ADMIN_EMAIL=admin@latiflandmark.com
ADMIN_PASSWORD=Admin@1234

# Frontend URLs (comma separated if multiple)
# Replace with your actual Netlify URLs after deploying
CLIENT_URL=https://your-frontend.netlify.app
